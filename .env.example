# Copia este archivo a .env y coloca tus credenciales reales de Twilio
# NOTA: Por defecto NO uses mock. Si quieres simular (no envía nada), define TWILIO_MOCK=1 temporalmente.

# Deja en blanco o elimina para envío real. Usa 1/true para simular.
TWILIO_MOCK=

# Credenciales Twilio (requeridas para envío real)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Desde: para SMS usa formato E.164; para WhatsApp NO incluyas el prefijo "whatsapp:" aquí
# Sandbox de WhatsApp (ejemplo): +14155238886 — Recuerda unirte enviando el código de sandbox desde tu número destino
# Producción: usa tu número de WhatsApp Business aprobado
TWILIO_FROM=

# Hacia: número destino (dueño) en formato E.164, ej. +521XXXXXXXXXX (NO incluyas "whatsapp:")
OWNER_PHONE=

# Canal de envío: sms o whatsapp
TWILIO_CHANNEL=whatsapp

# URL pública base (para enlaces de rastreo en el mensaje). En local:
PUBLIC_BASE_URL=http://localhost:3000

PORT=3000

# ==============================
# Firebase Admin (puntos al pagar)
# ==============================
# Para acreditar puntos en el momento de marcar "PAGADO" desde el panel, el servidor
# necesita acceso Admin a Firestore.
#
# Opción A (recomendada): ruta a tu JSON de Service Account descargado desde Firebase Console
# (Settings > Service accounts > Generate new private key)
FIREBASE_SERVICE_ACCOUNT_PATH=
#
# Opción B: pegar el JSON completo en una sola línea (escapeado) o como string JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
#
# Clave simple para proteger endpoints admin en red local (opcional pero recomendado)
ADMIN_KEY=
